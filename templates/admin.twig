{% extends "base.twig" %}

{% block content %}
    <main>
        <div class="container">
            {% if is_admin %}
                <section class="admin-section">
                    <div class="section-title">Users</div>
                    <form action="" class="admin-form">
                        {% for user in users %}
                            <div class="form-row{% if user.role === 'admin' %} disabled{% endif %}" data-user-id="{{ user.id }}">
                                <div class="form-group">
                                    <div class="form-group__title">User login: </div>
                                    <div class="form-group__value">{{ user.login }}</div>
                                </div>
                                <div class="form-group">
                                    <label for="user-role-{{ user.id }}">User role: </label>
                                    <div class="form-select">
                                        <select name="user_role" id="user-role-{{ user.id }}"{% if user.role === 'admin' %} disabled{% endif %}>
                                            <option value="admin" {{ user.role == 'admin' ? 'selected' }}>Admin</option>
                                            <option value="user" {{ user.role == 'user' ? 'selected' }}>User</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="user-approved-{{ user.id }}">Approved: </label>
                                    <div class="form-select">
                                    {% set approved = user.is_approved ? 'True' : 'False' %}
                                        <select name="user_approved" id="user-approved-{{ user.id }}"{% if user.role === 'admin' %} disabled{% endif %}>
                                            <option value="1" {{ user.is_approved ? 'selected' }}>True</option>
                                            <option value="0" {{ not user.is_approved ? 'selected' }}>False</option>
                                        </select>
                                    </div>
                                    <div class="form-button delete-user">🗑️</div>
                                </div>
                            </div>
                        {% endfor %}
                    </form>
                </section>
            {% endif %}
        </div>
    </main>
{% endblock %}

{% block scripts %}
    <script type="text/javascript">
        $(function () {
            const adminForm = $(".admin-form");

            adminForm.on("change", 'select[name="user_approved"]', function () {
                const row = $(this).closest(".form-row");
                const userId = row.data("user-id");
                const approvedValue = $(this).val();
                $.ajax({
                    url: "/ajax/admin-user-approve",
                    type: "POST",
                    dataType: "json",
                    data: {
                        user_id: userId,
                        user_approved: approvedValue
                    },
                    success: function (response) {
                        console.log("OK:", response);
                    },
                    error: function (xhr) {
                        console.log("FAILED", {
                        status: xhr.status,
                        statusText: xhr.statusText,
                        responseText: xhr.responseText
                        });
                        alert("Request failed: " + xhr.status);
                    }
                });
            });
            adminForm.on('change', 'select[name="user_role"]', function() {
                const $row = $(this).closest(".form-row");
                const userId = $row.data("user-id");
                const roleValue = $(this).val();
                
                $.ajax({
                    url: "/ajax/admin-user-role",
                    type: "POST",
                    dataType: "json",
                    data: {
                        user_id: userId,
                        user_role: roleValue
                    },
                    success: function (response) {
                        console.log("OK:", response);
                    },
                    error: function (xhr) {
                        console.log("FAILED", {
                        status: xhr.status,
                        statusText: xhr.statusText,
                        responseText: xhr.responseText
                        });
                        alert("Request failed: " + xhr.status);
                    }
                });
            });
            adminForm.on('click', '.delete-user', function() {
                const row = $(this).closest(".form-row");
                const userId = row.data("user-id");

                if(!confirm("Delete this user?")) {
                    return false;
                }
                $.ajax({
                    url: "/ajax/admin-user-delete",
                    type: "POST",
                    dataType: "json",
                    data: {
                        user_id: userId
                    },
                    success: function (response) {
                        location.reload();
                    },
                    error: function (xhr) {
                        console.log("FAILED", {
                        status: xhr.status,
                        statusText: xhr.statusText,
                        responseText: xhr.responseText
                        });
                        alert("Request failed: " + xhr.status);
                    }
                });
            })
        });
    </script>
{% endblock %}