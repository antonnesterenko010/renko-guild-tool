
{% extends "base.twig" %}

{% block content %}
    <main>
        <div class="container">
            <div class="login-block">
                <form class="form-login" method="POST">
                    <input type="text" name="login" placeholder="Login" required>
                    <input type="password" name="password" placeholder="Password" required>
                    <button type="submit" name="action" value="login" class="button success">🔐 Login</button>
                </form>
                <form class="form-login" method="POST">
                    <input type="text" name="login" placeholder="Login" required>
                    <input type="password" name="password" placeholder="Password" required>
                    <button type="submit" name="action" value="signup" class="button success">✍️ Sign Up</button>
                </form>
            </div>
                {% if error %}
                    <p class="warning">{{ error }}</p>
                {% endif %}
            <form class="form-login login-guest" method="POST">
                <button type="submit" name="action" value="guest" class="button">🥸 Continue as guest</button>
            </form>
        </div>
    </main>
{% endblock %}